<div class="max-w-md mx-auto mt-20 bg-white p-8 rounded-2xl shadow-xl">
    <h1 class="text-2xl font-bold text-center text-blue-900">Login Admin</h1>
    <% if (error) { %><div class="bg-red-100 text-red-700 p-2 rounded mt-4"><%= error %></div><% } %>
    <form method="POST" class="mt-6">
        <div class="mb-4"><label>Username</label><input type="text" name="username" class="w-full border rounded-lg px-3 py-2"></div>
        <div class="mb-4"><label>Password</label><input type="password" name="password" class="w-full border rounded-lg px-3 py-2"></div>
        <button class="w-full bg-blue-900 text-white py-2 rounded-lg">Login</button>
    </form>
</div>