<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Dashboard Admin</h1>
    <div class="space-x-3">
        <a href="/admin/upload-foto" class="bg-blue-600 text-white px-4 py-2 rounded-lg">📸 Kelola Foto Advokat</a>
        <a href="/admin/logout" class="bg-gray-500 text-white px-4 py-2 rounded-lg">Logout</a>
    </div>
</div>
<h2 class="text-xl font-semibold mb-4">Manajemen Pertanyaan Hukum</h2>
<div class="space-y-4">
    <% questions.forEach(q => { %>
    <div class="bg-white rounded-xl shadow p-5">
        <div class="flex justify-between"><div><p class="font-bold"><%= q.name %> (<%= q.email || 'tanpa email' %>)</p><p class="text-sm text-gray-500"><%= new Date(q.created_at).toLocaleString() %></p></div><a href="/admin/delete/<%= q.id %>" onclick="return confirm('Hapus?')" class="text-red-500 text-sm">Hapus</a></div>
        <p class="mt-2"><strong>Pertanyaan:</strong> <%= q.question %></p>
        <% if (q.is_answered) { %>
            <div class="mt-3 bg-green-50 p-3 rounded"><p><strong>Jawaban:</strong> <%= q.answer %></p></div>
        <% } else { %>
            <form method="POST" action="/admin/answer/<%= q.id %>" class="mt-3"><textarea name="answer" rows="3" class="w-full border rounded p-2" placeholder="Tulis jawaban..."></textarea><button class="mt-2 bg-blue-900 text-white px-4 py-1 rounded">Kirim Jawaban</button></form>
        <% } %>
    </div>
    <% }); %>
</div>